{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/webhook", "dest": "api/webhook.py" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  }
}
